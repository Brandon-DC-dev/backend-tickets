# filepath: .env.example
# Server
PORT=3000
NODE_ENV=development
API_PREFIX=/api

# Supabase — required
# Get these from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=YOUR-ANON-OR-PUBLISHABLE-KEY

# Supabase — optional (server-side only, NEVER expose to the browser)
# Leave empty unless you need to bypass Row Level Security on the server.
SUPABASE_SERVICE_ROLE_KEY=

# CORS — CSV de orígenes permitidos para el frontend.
# Formato: scheme://host[:puerto], sin espacios, separados por comas.
#   Dev local:
#     http://localhost:4321,http://127.0.0.1:4321
#   Producción (Vercel → Settings → Environment Variables):
#     https://frontend-tickets.vercel.app
# Si está vacía, app.js usa defaults razonables (localhost + dominio de prod
# conocido). En Vercel es ALTAMENTE recomendado setearlo explícitamente.
CORS_ORIGINS=